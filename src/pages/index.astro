---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import IssueRow from "../components/IssueRow.astro";
import StepsToReproduce from "../components/StepsToReproduce.astro";
import StyledInlineText from "../components/StyledInlineText.astro";
import RotatedCards from "../components/RotatedCards.astro";
import DiagonalButtons from "../components/DiagonalButtons.astro";
import img from "../assets/image.png";
import IssueTitle from "../components/IssueTitle.astro";
import timestamps from "../data/component-timestamps.json";

function commitLabel(iso: string): { ago: string; human: string } {
  if (!iso) return { ago: "never", human: "" };
  const date = new Date(iso);
  const diff = Date.now() - date.getTime();
  const mins = Math.floor(diff / 60000);
  let ago: string;
  if (mins < 1) ago = "just now";
  else if (mins < 60) ago = `${mins}m ago`;
  else if (mins < 1440) ago = `${Math.floor(mins / 60)}h ago`;
  else ago = `${Math.floor(mins / 1440)}d ago`;
  const human = date.toLocaleString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
    hour: "numeric",
    minute: "2-digit",
    hour12: true,
  });
  return { ago, human };
}

const ts = (key: string) =>
  commitLabel((timestamps as Record<string, string>)[key] ?? "");

const pageTs = ts("src/pages/index.astro");
const styledTs = ts("src/components/StyledInlineText.astro");
const diagonalTs = ts("src/components/DiagonalButtons.astro");
const rotatedTs = ts("src/components/RotatedCards.astro");
---

<Layout>
  <a
    href="https://github.com/YottaYocta/paper-localhost-snapshot"
    target="_blank"
    rel="noopener noreferrer"
    class="fixed top-4 left-6 text-gray-500 opacity-70 hover:opacity-100 transition-opacity duration-200 z-50"
    >Github Source</a
  >
  <main
    class="min-h-screen flex flex-col justify-center items-center px-12 py-16"
  >
    <div class="w-full max-w-6xl">
      <div class="lg:flex gap-20 pb-3 border-b border-gray-200 hidden">
        <div
          class="w-52 shrink-0 text-xs font-semibold text-gray-400 uppercase tracking-wide"
        >
          Experiment
        </div>
        <div
          class="w-72 shrink-0 text-xs font-semibold text-gray-400 uppercase tracking-wide"
        >
          Component
        </div>
        <div
          class="flex-1 text-xs font-semibold text-gray-400 uppercase tracking-wide"
        >
          Notes & Reproduction
        </div>
      </div>

      <!-- localhost paste -->
      <IssueRow id="localhost-paste">
        <IssueTitle
          slot="title"
          id="localhost-paste"
          ago={pageTs.ago}
          human={pageTs.human}
          >Paste fails when copying images from localhost</IssueTitle
        >
        <div slot="component" class="flex gap-8 items-start">
          <figure class="flex flex-col items-center gap-2">
            <Image
              src={img}
              alt="Astro Image component"
              width={100}
              height={100}
            />
            <figcaption class="text-xs text-gray-400">
              {"<Image>"} component
            </figcaption>
          </figure>
          <figure class="flex flex-col items-center gap-2">
            <img src={img.src} alt="img element" width="100" height="100" />
            <figcaption class="text-xs text-gray-400">
              {"<img>"} element
            </figcaption>
          </figure>
        </div>
        <div slot="notes">
          <StepsToReproduce>
            <li>
              Clone the repo:
              <span class="inline-flex items-center gap-2 mt-1">
                <code class="font-mono text-xs bg-gray-100 px-2 py-0.5 rounded"
                  >https://github.com/YottaYocta/paper-localhost-snapshot</code
                >
                <button
                  onclick="navigator.clipboard.writeText('https://github.com/YottaYocta/paper-localhost-snapshot')"
                  class="text-xs text-gray-400 hover:text-gray-700 border border-gray-200 rounded px-2 py-0.5 transition-colors cursor-pointer"
                  >copy</button
                >
              </span>
            </li>
            <li>Run the dev server and open the page in a browser.</li>
            <li>Copy one of the images in the component column.</li>
            <li>Paste into editor.</li>
          </StepsToReproduce>
        </div>
      </IssueRow>

      <!-- max-width paste -->
      <IssueRow id="max-width-paste">
        <IssueTitle
          slot="title"
          id="max-width-paste"
          ago={pageTs.ago}
          human={pageTs.human}
          >Max/min-width is kept when pasting snapshots to Paper</IssueTitle
        >
        <div slot="component">
          <div
            class="max-w-xs min-w-xs rounded-xl border border-gray-200 bg-white shadow-sm p-5"
          >
            <p class="text-xs font-semibold text-gray-700 mb-1">
              Card with max-width
            </p>
            <p class="text-xs text-gray-400 leading-relaxed">
              This element has <code class="font-mono bg-gray-100 px-1 rounded"
                >max-width</code
              > and <code class="font-mono bg-gray-100 px-1 rounded"
                >min-width</code
              > set. Copy and paste it into editor.
            </p>
          </div>
        </div>
        <div slot="notes">
          <p class="text-sm text-gray-500 leading-relaxed mb-4">
            When an element with a <code
              class="font-mono bg-gray-100 px-1 rounded text-xs">max-width</code
            > (or min-width) constraint is copied and pasted into editor, the pasted
            node inherits the constraint. There is no way to overwrite it without
            creating a new element.
          </p>
          <StepsToReproduce>
            <li>Copy the card in the component column.</li>
            <li>Paste it into the editor.</li>
            <li>
              Try to increase the pasted node's width beyond its max-width.
            </li>
          </StepsToReproduce>
        </div>
      </IssueRow>

      <!-- inline styled text -->
      <IssueRow id="inline-styled-text">
        <IssueTitle
          slot="title"
          id="inline-styled-text"
          ago={styledTs.ago}
          human={styledTs.human}>Inline styled text</IssueTitle
        >
        <div slot="component"><StyledInlineText /></div>
        <div slot="notes">
          Snapshot splits non-span elements into their own style, but eliminates
          any styling within a {"<p>"} tag if done through a span
        </div>
      </IssueRow>

      <!-- diagonal buttons -->
      <IssueRow id="diagonal-buttons">
        <IssueTitle
          slot="title"
          id="diagonal-buttons"
          ago={diagonalTs.ago}
          human={diagonalTs.human}>Diagonal buttons</IssueTitle
        >
        <div slot="component"><DiagonalButtons /></div>
        <div slot="notes">
          <code class="font-mono text-xs bg-gray-100 px-1 rounded"
            >clip-path</code
          > button preserved when copied to editor, but doesn't seem to be any option
          to edit. The other uses <code
            class="font-mono text-xs bg-gray-100 px-1 rounded">skew</code
          > and loses its styling
        </div>
      </IssueRow>

      <!-- complex transforms -->
      <IssueRow id="complex-transforms">
        <IssueTitle
          slot="title"
          id="complex-transforms"
          ago={rotatedTs.ago}
          human={rotatedTs.human}>Complex transforms</IssueTitle
        >
        <div slot="component"><RotatedCards /></div>
        <div slot="notes">
          Visually works for me. rotation also preserved in editor
        </div>
      </IssueRow>
    </div>
  </main>
</Layout>
