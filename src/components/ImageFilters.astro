---
import { Image } from "astro:assets";
import img from "../assets/image.png";
---

<div class="flex gap-8 items-end flex-wrap">
  <figure class="flex flex-col items-center gap-2">
    <div class="relative w-27.5 h-27.5">
      <Image src={img} alt="" width={100} height={100} />
      <Image
        src={img}
        alt=""
        width={100}
        height={100}
        style="position:absolute;top:10px;left:10px;mix-blend-mode:multiply;filter:hue-rotate(180deg);"
      />
    </div>
    <figcaption class="text-xs text-gray-400 text-center">multiply + hue-rotate</figcaption>
  </figure>

  <figure class="flex flex-col items-center gap-2">
    <div class="relative w-27.5 h-27.5">
      <Image src={img} alt="" width={100} height={100} />
      <Image
        src={img}
        alt=""
        width={100}
        height={100}
        style="position:absolute;top:10px;left:10px;mix-blend-mode:screen;filter:invert(1);"
      />
    </div>
    <figcaption class="text-xs text-gray-400 text-center">screen + invert</figcaption>
  </figure>

  <figure class="flex flex-col items-center gap-2">
    <div class="relative w-27.5 h-27.5">
      <Image src={img} alt="" width={100} height={100} style="filter:grayscale(1);" />
      <Image
        src={img}
        alt=""
        width={100}
        height={100}
        style="position:absolute;top:10px;left:10px;mix-blend-mode:overlay;opacity:0.7;"
      />
    </div>
    <figcaption class="text-xs text-gray-400 text-center">grayscale + overlay</figcaption>
  </figure>
</div>
