<div class="flex flex-col gap-4">
  <div class="relative inline-flex items-center">
    <span
      class="absolute inset-0 bg-gray-200"
      style="clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 100%, 12px 100%)"
    ></span>
    <span
      class="relative px-6 py-2 text-xs font-semibold text-black tracking-wide"
    >
      clip-path button
    </span>
  </div>

  <div class="relative inline-flex items-center">
    <span class="absolute inset-0 bg-gray-200 -skew-x-6"></span>
    <span
      class="relative px-6 py-2 text-xs font-semibold text-black tracking-wide"
    >
      skew button
    </span>
  </div>
</div>
